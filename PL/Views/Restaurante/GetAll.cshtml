
@{
    ViewData["Title"] = "GetAll";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Restaurante</h1>

<hr />

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Logo</th>
            <th>Fecha Apertura</th>
            <th>Fecha Cierre</th>
            <th>Direccion</th>
            <th>Acciones</th>

        </tr>
    </thead>
    <tbody id="restauranteTabla">

        @* Esto se hace en el json *@


    </tbody>

</table>

<!--  MODAL EDITAR  -->
<div class="modal fade" id="modalRestaurante" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Editar Restaurante</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- IDs ocultos -->
                <input type="hidden" id="IdRestaurante" />
                <input type="hidden" id="IdDireccion" />

                <div class="mb-3">
                    <label>Nombre</label>
                    <input type="text" id="Nombre" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Fecha Apertura</label>
                    <input type="date" id="FechaApertura" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Fecha Cierre</label>
                    <input type="date" id="FechaCierre" class="form-control" />
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-success" onclick="Update()">Guardar</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>

        </div>
    </div>
</div>



<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/RestauranteCRUD/CRUD.js"></script>



